━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

00:04:38.831 --> 00:04:42.345
金利が上がっても円高にならないことの意味

00:04:42.345 --> 00:04:51.657
こんしゅう日本の債券しじょうでは長期金利の指標となる新発10年物国債利回りが一時2.9％まで上昇しました。

00:04:51.657 --> 00:05:00.442
これは1996年9月いらいの高水準ですが、こんご3％を超えるのではないかという声も増えてきています。

00:05:00.442 --> 00:05:05.010
金利が上昇すればその国の通貨は上昇するのが通例です。

00:05:05.010 --> 00:05:11.686
しかし今回日本の長期金利が上昇しているにもかかわらず円高には振れていません。

00:05:11.686 --> 00:05:26.269
その背景には、引き続き海外に比べ相対的に低い金利水準であることや、インフレ率を加味した日本の実質金利がマイナスであることも円高になりにくい要因として指摘されています。

00:05:26.269 --> 00:05:35.932
最大の要因は現在の日本の長期金利上昇が景気回復による資金じゅようの強まりといった前向きな理由ではないことです。

00:05:35.932 --> 00:05:45.771
財政赤字拡大への警戒感やそれに伴う国債の需給悪化といった国債の信用力低下による悪い金利上昇を反映しているのです。

00:05:45.771 --> 00:05:56.489
国の財政リスクの高まりによる需給懸念からの金利上昇は通貨の買いの要因ではなく、むしろ通貨売りの要因として働いてしまいます。

00:05:56.489 --> 00:06:08.612
為替に関しては金利に関係なく、新ニーサの普及から個人の投資資金が海外の株式や投資信託へと継続的に流出していることが円安をもたらしています。

00:06:08.612 --> 00:06:18.275
さらに貿易収支の動向やエネルギー資源の輸入に伴う企業側のドル買い需要も金利とは直接関係ない円安要因となります。

00:06:18.275 --> 00:06:25.479
金利が上がるのに為替の円安が進むという状況は日本経済の厳しい現実の反映と言えます。

00:06:25.479 --> 00:06:28.290
自分の資産をどうやって守るのか。

00:06:28.290 --> 00:06:32.858
国に頼らないで自分で考え行動しななければなりません。

00:06:32.858 --> 00:06:39.183
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

